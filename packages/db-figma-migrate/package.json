{
  "name": "@db-ux/db-figma-migrate",
  "private": true,
  "version": "1.0.0",
  "description": "Modular migration framework for DB UX Design System major releases",
  "main": "index.js",
  "workspaces": [
    "plugin/*",
    "ui/*"
  ],
  "scripts": {
    "build": "npm-run-all --parallel build:*",
    "build:code": "npm run build -w=db-figma-migrate-code -- --minify",
    "build:ui": "npm run build -w=db-figma-migrate-ui",
    "dev": "npm-run-all --parallel dev:*",
    "dev:code": "npm run dev -w=db-figma-migrate-code",
    "dev:ui": "npm run dev -w=db-figma-migrate-ui"
  },
  "author": "",
  "license": "Apache-2.0"
}
